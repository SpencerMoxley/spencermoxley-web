---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { withBase } from '../../lib/assetPath';

export const getStaticPaths = (async () => {
  // Drafts are excluded from production builds but browsable in dev.
  const posts = (await getCollection('blog')).filter(
    (post) => import.meta.env.DEV || !post.data.draft
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${post.data.title} | Spencer Moxley`} description={post.data.description}>
  <Header />
  <main id="main-content" class="post-page">
    <article class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl py-28 sm:py-32">
      <a href={withBase('/blog')} class="back-link">← Back to blog</a>

      <header class="post-header">
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {dateFormatter.format(post.data.date)}
        </time>
        <h1 class="post-title gradient-text">{post.data.title}</h1>
        {
          post.data.tags.length > 0 && (
            <ul class="post-tags">
              {post.data.tags.map((tag) => (
                <li class="post-tag">{tag}</li>
              ))}
            </ul>
          )
        }
      </header>

      <div class="prose-section">
        <Content />
      </div>

      <footer class="post-footer">
        <a href={withBase('/blog')} class="back-link">← Back to blog</a>
      </footer>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .post-page {
    background-color: var(--bg);
    min-height: 100vh;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--text-dim);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .back-link:hover {
    color: var(--accent);
  }

  .post-header {
    margin: 2rem 0 2.5rem;
  }
  .post-date {
    display: block;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }
  .post-title {
    font-size: 2.25rem;
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  @media (min-width: 640px) {
    .post-title {
      font-size: 2.75rem;
    }
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .post-tag {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-dim);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
  }

  .post-footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  /* Markdown content — mirrors the prose pattern used on the privacy/terms pages
     so blog posts inherit the site's typography and theme tokens. */
  .prose-section :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin: 2.5rem 0 0.75rem;
  }
  .prose-section :global(h3) {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin: 2rem 0 0.5rem;
  }
  .prose-section :global(p) {
    color: var(--text-muted);
    line-height: 1.85;
    margin-bottom: 1.15rem;
  }
  .prose-section :global(ul),
  .prose-section :global(ol) {
    color: var(--text-muted);
    line-height: 1.85;
    padding-left: 1.5rem;
    margin-bottom: 1.15rem;
  }
  .prose-section :global(ul) {
    list-style: disc;
  }
  .prose-section :global(ol) {
    list-style: decimal;
  }
  .prose-section :global(li) {
    margin-bottom: 0.45rem;
  }
  .prose-section :global(li)::marker {
    color: var(--text-dim);
  }
  .prose-section :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.2s ease;
  }
  .prose-section :global(a:hover) {
    opacity: 0.8;
  }
  .prose-section :global(strong) {
    color: var(--text);
    font-weight: 700;
  }
  .prose-section :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-dim);
    font-style: italic;
  }
  .prose-section :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.875em;
    color: var(--text);
    background: var(--bg-surface);
    padding: 0.1em 0.4em;
    border-radius: 0.3rem;
  }
  .prose-section :global(pre) {
    background: var(--bg-card-solid);
    border: 1px solid var(--border);
    border-radius: 0.6rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-section :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: 0.85rem;
  }
  .prose-section :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.6rem;
    margin: 1.5rem 0;
  }
  .prose-section :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
</style>
