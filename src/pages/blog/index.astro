---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { withBase } from '../../lib/assetPath';

// Newest first. Drafts are shown in dev but hidden from production builds.
const posts = (await getCollection('blog'))
  .filter((post) => import.meta.env.DEV || !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title="Blog | Spencer Moxley"
  description="Writing on tech, homelab and infrastructure, coding, philosophy, and competitive debate."
>
  <Header />
  <main id="main-content" class="blog-page">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl py-28 sm:py-32">
      <header class="blog-intro">
        <p class="blog-eyebrow">Writing</p>
        <h1 class="text-4xl sm:text-5xl font-bold gradient-text">Blog</h1>
        <p class="blog-lede">
          Notes on homelab and infrastructure, coding, philosophy, and competitive debate —
          thinking out loud and keeping a record as I go.
        </p>
      </header>

      {
        posts.length === 0 ? (
          <p class="blog-empty">No posts yet. Check back soon.</p>
        ) : (
          <ul class="blog-list">
            {posts.map((post) => (
              <li>
                <a href={withBase(`/blog/${post.id}`)} class="card blog-card">
                  <time class="blog-card-date" datetime={post.data.date.toISOString()}>
                    {dateFormatter.format(post.data.date)}
                  </time>
                  <h2 class="blog-card-title">{post.data.title}</h2>
                  <p class="blog-card-desc">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <ul class="blog-tags">
                      {post.data.tags.map((tag) => (
                        <li class="blog-tag">{tag}</li>
                      ))}
                    </ul>
                  )}
                  <span class="blog-card-more">Read post →</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .blog-page {
    background-color: var(--bg);
    min-height: 100vh;
  }

  .blog-intro {
    margin-bottom: 3rem;
  }
  .blog-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }
  .blog-lede {
    color: var(--text-muted);
    line-height: 1.8;
    margin-top: 1rem;
    max-width: 42rem;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .blog-card {
    display: block;
  }
  .blog-card-date {
    display: block;
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 0.4rem;
  }
  .blog-card-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 0.5rem;
    transition: color 0.2s ease;
  }
  .blog-card:hover .blog-card-title {
    color: var(--accent);
  }
  .blog-card-desc {
    color: var(--text-muted);
    line-height: 1.7;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.9rem;
  }
  .blog-tag {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-dim);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
  }

  .blog-card-more {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
  }

  .blog-empty {
    color: var(--text-muted);
  }
</style>
